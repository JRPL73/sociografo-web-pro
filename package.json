{
  "name": "sociografo-web-pro",
  "version": "1.0.0",
  "description": "Herramienta de Análisis Grupal",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.sociografo.app",
    "productName": "SocioGrafo",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "lucide-react": "^0.378.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  }
}
